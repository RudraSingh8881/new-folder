<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Main File</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <h1>Rudra</h1>
    <% for(post of posts){%>
        <div class="post">
            <h3 class="user"><%=post.username %></h3>
            <h4 class="contact"><%=post.contact %></h4>
            <a href="http://localhost:3000/posts/<%=post.id %>">see details</a>
            <a href="http://localhost:3000/posts/<%=post.id %>/edit">Edit</a>
            <form method="post"action="/posts/<%=post.id%>?_method=DELETE">
                <button>Delete</button>
            </form>
        </div>
    <%}%>
    <br/><br/>
     <a href="http://localhost:3000/posts/new">create posts</a>
</body>
</html>